#!/usr/bin/env bash
set -e

use_link=false

if [ "$1" = "-l" ]; then
    use_link=true
    shift
fi

input="$1"

if [ -z "$input" ]; then
    echo "Usage:" >&2
    echo "  $0 <problem-name>" >&2
    echo "  $0 -l <kattis-url>" >&2
    exit 1
fi

# ==========================
# Dependency check
# ==========================
require() {
    if ! command -v "$1" >/dev/null 2>&1; then
        echo "Missing dependency: $1" >&2
        exit 1
    fi
}

require curl
require unzip
require diff

# ==========================
# Base directory
# ==========================
KATTIS_DIR="${KATTIS_DIR:-$HOME/kattis}"
mkdir -p "$KATTIS_DIR"

# ==========================
# Extract name
# ==========================
if $use_link; then
    input="${input%/}"
    input="${input%%\?*}"
    name="${input##*/}"
else
    name="$input"
fi

problem_dir="$KATTIS_DIR/problems/$name"
url="https://open.kattis.com/problems/$name"

# ==========================
# Validate problem
# ==========================
status=$(curl -s -o /dev/null -w "%{http_code}" -L "$url")

if [ "$status" != "200" ]; then
    echo "Problem does not exist" >&2
    exit 1
fi

# ==========================
# Create directory
# ==========================
mkdir -p "$problem_dir"

# ==========================
# Language selection
# ==========================
echo "Select language:"
echo "1) Python"
echo "2) Java"
read -rp "Choice [1-2]: " choice

case "$choice" in
    1)
        ext="py"
        run_cmd='./soln.py'
        require python3
        ;;
    2)
        ext="java"
        run_cmd='javac soln.java && java soln'
        require javac
        require java
        ;;
    *)
        echo "Invalid choice, defaulting to Python"
        ext="py"
        run_cmd='./soln.py'
        require python3
        ;;
esac

# ==========================
# Solution file (with template)
# ==========================
soln_file="$problem_dir/soln.$ext"

if [ -f "$soln_file" ]; then
    echo "soln.$ext already exists - skipping" >&2
elif [ -f "${name}.$ext" ]; then
    mv "${name}.$ext" "$soln_file"
else
    if [ "$ext" = "py" ]; then
        cat <<EOF > "$soln_file"
#!/usr/bin/env python3

def main():
    # input code here
    pass


if __name__ == "__main__":
    main()
EOF
chmod +x "$soln_file"
elif [ "$ext" = "java" ]; then
    cat <<EOF > "$soln_file"
import java.util.*;

public class soln {
    public static void main(String[] args) {
        // input code here
    }
}
EOF
fi
    fi

# ==========================
# README
# ==========================
[ -f "$problem_dir/README.md" ] || echo "$url" > "$problem_dir/README.md"

# ==========================
# Samples
# ==========================
samples_url="https://open.kattis.com/problems/$name/file/statement/samples.zip"

tmp_zip="$problem_dir/samples.zip"
tmp_dir="$problem_dir/_samples"

if curl -fsSL -L "$samples_url" -o "$tmp_zip"; then
    mkdir -p "$tmp_dir"
    unzip -q "$tmp_zip" -d "$tmp_dir"

    i=1
    found=false

    for infile in "$tmp_dir"/*.in; do
        [ -e "$infile" ] || continue

        base="$(basename "$infile" .in)"
        outfile="$tmp_dir/$base.ans"

        if [ -f "$outfile" ]; then
            cp "$infile" "$problem_dir/in$i"
            cp "$outfile" "$problem_dir/out$i"
            i=$((i + 1))
            found=true
        fi
    done

    rm -rf "$tmp_zip" "$tmp_dir"

    if ! $found; then
        echo "No valid samples found, creating base in/out" >&2
        touch "$problem_dir/in" "$problem_dir/out"
    fi
else
    echo "Sample download failed, creating base in/out" >&2
    touch "$problem_dir/in" "$problem_dir/out"
fi

# ==========================
# Test runner
# ==========================
test_script="$problem_dir/test"

cat <<EOF > "$test_script"
#!/usr/bin/env bash
set -e

echo "Running tests..."

passed=0
failed=0

for infile in in*; do
    [ -e "\$infile" ] || continue

    num=\${infile#in}
    outfile="out\$num"

    echo "Test \$num:"

    if $run_cmd < "\$infile" | diff -u - "\$outfile"; then
        echo "PASS"
        passed=\$((passed+1))
    else
        echo "FAIL"
        failed=\$((failed+1))
    fi

    echo "----------------------"
done

echo "Passed: \$passed"
echo "Failed: \$failed"
EOF

chmod +x "$test_script"

echo "Setup complete for $name" >&2
echo "$problem_dir"
