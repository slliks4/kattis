#!/usr/bin/env bash
set -e

use_link=false

if [ "$1" = "-l" ]; then
    use_link=true
    shift
fi

input="$1"

if [ -z "$input" ]; then
    echo "Usage:" >&2
    echo "  $0 <problem-name>" >&2
    echo "  $0 -l <kattis-url>" >&2
    exit 1
fi

# extract name
if $use_link; then
    input="${input%/}"
    input="${input%%\?*}"
    name="${input##*/}"
else
    name="$input"
fi

url="https://open.kattis.com/problems/$name"

# check if problem exists
status=$(curl -s -o /dev/null -w "%{http_code}" "$url")

if [ "$status" = "404" ]; then
    echo "Problem does not exist" >&2
    exit 1
fi

# create directory
mkdir -p "$name"

# solution file
if [ -f "${name}/soln.py" ]; then
    echo "soln.py already exists - skipping" >&2
elif [ -f "${name}.py" ]; then
    mv "${name}.py" "${name}/soln.py"
else
    touch "$name/soln.py"
fi

# README
[ -f "$name/README.md" ] || echo "$url" > "$name/README.md"

# download samples
samples_url="https://open.kattis.com/problems/$name/file/statement/samples.zip"

tmp_zip="$name/samples.zip"
tmp_dir="$name/_samples"

if curl -fsSL -L "$samples_url" -o "$tmp_zip"; then
    mkdir -p "$tmp_dir"
    unzip -q "$tmp_zip" -d "$tmp_dir"

    i=1
    found=false

    for infile in "$tmp_dir"/*.in; do
        [ -e "$infile" ] || continue

        base="$(basename "$infile" .in)"
        outfile="$tmp_dir/$base.ans"

        if [ -f "$outfile" ]; then
            cp "$infile" "$name/in$i"
            cp "$outfile" "$name/out$i"
            i=$((i + 1))
            found=true
        fi
    done

    rm -rf "$tmp_zip" "$tmp_dir"

    if ! $found; then
        echo "No valid samples found in zip, creating base in/out" >&2
        touch "$name/in" "$name/out"
    fi
else
    echo "Sample download failed, creating base in/out" >&2
    touch "$name/in" "$name/out"
fi

echo "Setup complete for $name" >&2

echo "cd \"$name\""
